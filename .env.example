# ALGO-FRONTEND Trading Platform Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://username:password@host:port/trading_db
REDIS_URL=redis://username:password@host:port/0

# For DigitalOcean Managed Databases, use the connection strings from your dashboard
# Format: postgresql://doadmin:password@db-postgresql-nyc3-12345-do-user-123456-0.b.db.ondigitalocean.com:25060/defaultdb?sslmode=require
# Format: rediss://default:password@redis-calm-12345-do-user-123456-0.b.db.ondigitalocean.com:25061

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
PAPER_TRADING=true
AUTONOMOUS_TRADING_ENABLED=true
INTRADAY_TRADING_ENABLED=true
ELITE_RECOMMENDATIONS_ENABLED=true

# Risk Management
DAILY_STOP_LOSS_PERCENT=2.0
MAX_POSITIONS=10
AUTO_SQUARE_OFF_ENABLED=true
AUTO_TARGET_BOOKING=true
AUTO_STOP_LOSS=true

# =============================================================================
# ZERODHA CONFIGURATION
# =============================================================================
# Get these from https://kite.trade/
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_CLIENT_ID=your_client_id
ZERODHA_ACCOUNT_NAME=your_account_name

# =============================================================================
# TRUEDATA CONFIGURATION
# =============================================================================
# Get these from https://truedata.in/
TRUEDATA_USERNAME=your_truedata_username
TRUEDATA_PASSWORD=your_truedata_password
TRUEDATA_URL=push.truedata.in
TRUEDATA_PORT=8086
DATA_PROVIDER_ENABLED=false

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECRET_KEY=your_super_secret_key_change_this_in_production
JWT_SECRET=your_jwt_secret_key_change_this_in_production
ADMIN_PASSWORD=your_admin_password_change_this

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
LOG_LEVEL=INFO
ENABLE_LOGGING=true
LOG_FILE_PATH=/var/log/algo-trading/
ENABLE_METRICS=true

# =============================================================================
# EXTERNAL SERVICES (Optional)
# =============================================================================
# Email notifications
EMAIL_SERVICE_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# PRODUCTION SPECIFIC
# =============================================================================
NODE_ENV=production
REACT_APP_BACKEND_URL=https://your-domain.com

# CORS Origins (comma separated)
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_ENABLED=true