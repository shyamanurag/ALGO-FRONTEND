# Elite Autonomous Trading Platform - Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://username:password@host:port/database_name
REDIS_URL=redis://username:password@host:port

# Trading Configuration
PAPER_TRADING=true
AUTONOMOUS_TRADING_ENABLED=true
INTRADAY_TRADING_ENABLED=true
ELITE_RECOMMENDATIONS_ENABLED=true
DATA_PROVIDER_ENABLED=true

# Risk Management
AUTO_SQUARE_OFF_ENABLED=true
AUTO_TARGET_BOOKING=true
AUTO_STOP_LOSS=true
DAILY_STOP_LOSS_PERCENT=2.0

# Security Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Market Data API Credentials
TRUEDATA_USERNAME=your_truedata_username
TRUEDATA_PASSWORD=your_truedata_password
TRUEDATA_URL=push.truedata.in
TRUEDATA_PORT=8086
TRUEDATA_SANDBOX=false

# Broker API Credentials
ZERODHA_API_KEY=your_zerodha_api_key
ZERODHA_API_SECRET=your_zerodha_api_secret
ZERODHA_CLIENT_ID=your_zerodha_client_id
ZERODHA_ACCOUNT_NAME=your_account_name

# Application Configuration
NODE_ENV=development
PYTHON_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Frontend Configuration
REACT_APP_BACKEND_URL=http://localhost:8001
REACT_APP_APP_NAME=Elite Autonomous Trading Platform
REACT_APP_VERSION=3.1.0
REACT_APP_PAPER_TRADING_DEFAULT=true
REACT_APP_REAL_TIME_UPDATES=true
REACT_APP_WEBSOCKET_ENABLED=true
REACT_APP_THEME=dark
REACT_APP_AUTO_REFRESH_INTERVAL=30000